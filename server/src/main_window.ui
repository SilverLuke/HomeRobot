<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkApplicationWindow" id="main_window">
    <property name="title">HomeRobot Control Center</property>
    <property name="default-width">1200</property>
    <property name="default-height">800</property>
    
    <child type="titlebar">
      <object class="GtkHeaderBar">
        <child type="end">
          <object class="GtkLabel" id="battery_label">
            <property name="label">Battery: --% (-- mV)</property>
            <property name="margin-end">12</property>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="spacing">6</property>
        <property name="margin-start">6</property>
        <property name="margin-end">6</property>
        <property name="margin-top">6</property>
        <property name="margin-bottom">6</property>

        <!-- Sidebar: Configuration & Telemetry -->
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="width-request">300</property>
            <property name="spacing">12</property>

            <!-- Motor Configuration -->
            <child>
              <object class="GtkFrame">
                <property name="label">Motor Configuration (PID)</property>
                <child>
                  <object class="GtkGrid">
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">10</property>
                    <property name="margin-bottom">10</property>
                    <property name="row-spacing">6</property>
                    <property name="column-spacing">12</property>

                    <!-- Header Row -->
                    <child>
                      <object class="GtkLabel">
                        <property name="label">P</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">I</property>
                        <layout>
                          <property name="column">2</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">D</property>
                        <layout>
                          <property name="column">3</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>

                    <!-- Left Motor Row -->
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Left</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="kp_left">
                        <property name="focusable">false</property>
                        <property name="can-focus">false</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">100</property>
                            <property name="step-increment">0.01</property>
                            <property name="page-increment">0.1</property>
                          </object>
                        </property>
                        <property name="digits">3</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="ki_left">
                        <property name="focusable">false</property>
                        <property name="can-focus">false</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">100</property>
                            <property name="step-increment">0.001</property>
                            <property name="page-increment">0.01</property>
                          </object>
                        </property>
                        <property name="digits">3</property>
                        <layout>
                          <property name="column">2</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="kd_left">
                        <property name="focusable">false</property>
                        <property name="can-focus">false</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">100</property>
                            <property name="step-increment">0.01</property>
                            <property name="page-increment">0.1</property>
                          </object>
                        </property>
                        <property name="digits">3</property>
                        <layout>
                          <property name="column">3</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>

                    <!-- Right Motor Row -->
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Right</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="kp_right">
                        <property name="focusable">false</property>
                        <property name="can-focus">false</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">100</property>
                            <property name="step-increment">0.01</property>
                            <property name="page-increment">0.1</property>
                          </object>
                        </property>
                        <property name="digits">3</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="ki_right">
                        <property name="focusable">false</property>
                        <property name="can-focus">false</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">100</property>
                            <property name="step-increment">0.001</property>
                            <property name="page-increment">0.01</property>
                          </object>
                        </property>
                        <property name="digits">3</property>
                        <layout>
                          <property name="column">2</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="kd_right">
                        <property name="focusable">false</property>
                        <property name="can-focus">false</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">100</property>
                            <property name="step-increment">0.01</property>
                            <property name="page-increment">0.1</property>
                          </object>
                        </property>
                        <property name="digits">3</property>
                        <layout>
                          <property name="column">3</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>

                    <child>
                      <object class="GtkButton" id="apply_config">
                        <property name="focusable">false</property>
                        <property name="can-focus">false</property>
                        <property name="label">Apply Settings</property>
                        <property name="halign">center</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">4</property>
                          <property name="column-span">4</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- Encoders & Speed -->
            <child>
              <object class="GtkFrame">
                <property name="label">Odometry &amp; Dynamics</property>
                <child>
                  <object class="GtkListBox">
                    <property name="selection-mode">none</property>
                    <child>
                      <object class="GtkBox">
                        <property name="margin-start">10</property>
                        <property name="margin-end">10</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Left Encoder:</property>
                            <property name="hexpand">true</property>
                            <property name="xalign">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="enc_left_val">
                            <property name="label">0</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="margin-start">10</property>
                        <property name="margin-end">10</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Right Encoder:</property>
                            <property name="hexpand">true</property>
                            <property name="xalign">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="enc_right_val">
                            <property name="label">0</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- IMU Data -->
            <child>
              <object class="GtkFrame">
                <property name="label">IMU Sensor</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <child>
                      <object class="GtkLabel" id="accel_label">
                        <property name="label">Accel: X: 0.00 Y: 0.00 Z: 0.00</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="gyro_label">
                        <property name="label">Gyro: X: 0.00 Y: 0.00 Z: 0.00</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- Keyboard Shortcuts Help -->
            <child>
              <object class="GtkFrame">
                <property name="label">Keyboard Shortcuts</property>
                <child>
                  <object class="GtkLabel">
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">10</property>
                    <property name="margin-bottom">10</property>
                    <property name="xalign">0</property>
                    <property name="label">W: Forward
A: Turn Left
S: Backward
D: Turn Right
L: Start LiDAR
K: Stop LiDAR
T: Run Diagnostics
Space: STOP ALL</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Main Area: Lidar Canvas -->
        <child>
          <object class="GtkFrame">
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <child>
              <object class="GtkDrawingArea" id="lidar_canvas">
                <property name="focusable">true</property>
                <property name="content-width">600</property>
                <property name="content-height">600</property>
              </object>
            </child>
          </object>
        </child>

      </object>
    </child>
  </object>
</interface>
