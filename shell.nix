{
  pkgs ? import <nixpkgs> {
    config = {
      permittedInsecurePackages = [
        "python3.13-ecdsa-0.19.1"
      ];
    };
  },
}:

let
  # Fetch west2nix from GitHub as in the original file
#  west2nix = pkgs.callPackage (pkgs.fetchFromGitHub {
#    owner = "adisbladis";
#    repo = "west2nix";
#    rev = "f84670d66f881d9340b7d7626fbfe499438c134b";
#    hash = "sha256-D6iH0d67AmlB7k3QIjUvNo7NafzWy03HOHV5o4w251s=";
#  }) { callPackage = pkgs.callPackage; python3 = pkgs.python3; };

  # Check for projects.nix generated by 'west2nix convert'
#  evaluatedProjects = builtins.tryEval (import ./projects.nix);
#  projects = if evaluatedProjects.success && (builtins.readFile ./projects.nix) != "" then evaluatedProjects.value else null;

#  hookContent = if projects != null
#    then west2nix.mkWest2nixHook { manifest = projects; }
#    else "";

  # A comprehensive Python environment for Zephyr development, using the "Nix way"
  pythonEnv = pkgs.python3.withPackages (
    ps: with ps; [
      # Base requirements from requirements-base.txt
      anytree
      canopen
      intelhex
      jsonschema
      packaging
      patool
      psutil
      pyelftools
      pykwalify
      pylink-square
      pyserial
      pyyaml
      requests
      reuse
      semver
      setuptools
      tqdm
      west
      wheel
      # Build/Test requirements
      colorama
      ply
      coverage
      pytest
      mypy
      junitparser
      python-dotenv
      protobuf
      # Runtime/Test requirements
      pyocd
      tabulate
      natsort
      cbor
      python-can
      spdx-tools
      # For menuconfig/guiconfig
      tkinter
      ecdsa
    ]
  );

in
pkgs.mkShell {
  nativeBuildInputs = with pkgs; [
    # System dependencies for Zephyr and Server
    SDL2
    cargo
    rustc
    ccache
    cmake
    dfu-util
    dtc
    esptool # For ESP32 flashing
    file
    gcc
    gcovr
    git
    gperf
    libusb1 # For flashing/debugging
    ncurses
    ninja
    pkg-config
    protobuf
    unzip
    wget
    which
    xz

    # The Python environment with all dependencies
    pythonEnv

    # The west2nix tool itself for managing the workspace

  ];

  # Environment variables and shell logic
  shellHook = ''
    echo "--- Zephyr NixOS Environment (with west2nix) ---"

    # Set SDK and Toolchain variables
    if [ -d "$PWD/zephyr-port/zephyr-sdk-1.0.0" ]; then
      export ZEPHYR_SDK_INSTALL_DIR="$PWD/zephyr-port/zephyr-sdk-1.0.0"
      export ZEPHYR_TOOLCHAIN_VARIANT="zephyr"
      echo "Set ZEPHYR_SDK_INSTALL_DIR to $ZEPHYR_SDK_INSTALL_DIR"
    else
      echo "WARNING: ZEPHYR_SDK_INSTALL_DIR not found at $PWD/zephyr-port/zephyr-sdk-1.0.0"
    fi

    # Source environment variables if .env file exists
    if [ -f .env ]; then
      echo "Sourcing .env file"
      set -o allexport
      source .env
      set +o allexport
    fi

    # Robustly check if projects.nix exists to drive west2nix logic
    # Robustly check if projects.nix exists to drive west2nix logic
    # INFO: west2nix integration is temporarily disabled due to an upstream bug.
    #       Please run 'west2nix convert' manually if you wish to use it.

    # Set ZEPHYR_BASE. If west2nix is used, it should have created the zephyr directory.
    if [ -d "$PWD/zephyrproject/zephyr" ]; then
      export ZEPHYR_BASE="$PWD/zephyrproject/zephyr"
      echo "Set ZEPHYR_BASE to $ZEPHYR_BASE"
    else
      echo "WARNING: Could not determine ZEPHYR_BASE."
    fi

    # Configure ccache
    export CCACHE_DIR="$PWD/.ccache"
    export PATH="${pkgs.ccache}/lib/ccache:$PATH"
    # Ensure CMake (used by Zephyr/West) uses ccache
    export CMAKE_C_COMPILER_LAUNCHER=ccache
    export CMAKE_CXX_COMPILER_LAUNCHER=ccache

    echo "ccache configured at $CCACHE_DIR"
    echo "Nix shell is ready. You can now use 'west' and other Zephyr tools."
  '';
}
